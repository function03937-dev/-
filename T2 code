while max_num // exp > 0:
        buckets = [[] for _ in range(10)]

        # Distribute elements into buckets
        for num in arr:
            digit = (num // exp) % 10
            buckets[digit].append(num)

        # Collect elements from buckets
        arr = []
        for bucket in buckets:
            arr += bucket

        exp *= 10

    return arr
